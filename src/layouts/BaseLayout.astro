---
import '../styles/global.css';
import { Icon } from 'astro-icon/components';
import { ClientRouter } from 'astro:transitions';

interface Props {
  lang: string;
  title: string;
  description: string;
  robotsContent?: string;
  canonicalUrl?: string;
  languageAlternates?: Array<{ hreflang: 'ru' | 'en' | 'x-default'; href: string }>;
  openGraph?: {
    imageUrl: string;
    imageAlt: string;
  };
  structuredData?: Record<string, unknown>;
}

const {
  lang,
  title,
  description,
  robotsContent,
  canonicalUrl,
  languageAlternates = [],
  openGraph,
  structuredData,
} = Astro.props;
const ogLocale = lang === 'ru' ? 'ru_RU' : 'en_US';
const ogAlternateLocale = lang === 'ru' ? 'en_US' : 'ru_RU';
const isProduction = import.meta.env.PROD;
const skipLinkText =
  lang === 'ru' ? 'Перейти к основному содержимому' : 'Skip to main content';
const languageSwitcherLabel =
  lang === 'ru' ? 'Выбор языка' : 'Language selection';
const hasProfilePhoto = Astro.slots.has('profile-photo');
const hasSidebar =
  hasProfilePhoto || Astro.slots.has('sidebar-content');
const hasLanguageSwitcher = Astro.slots.has('language-switcher');
const hasProfileHeader =
  Astro.slots.has('profile-name') || Astro.slots.has('profile-role');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    {
      isProduction && (
        <meta
          http-equiv="Content-Security-Policy"
          content="default-src 'self'; base-uri 'none'; object-src 'none'; script-src 'self' https://mc.yandex.ru https://yastatic.net 'sha256-q4jrxcwKxo+EhsnGdsbJ0DxqAHu+9jqIrBQ/vPUn4Oo=' 'sha256-5Hj4fSaGCDqsGM1iQ1L1lZkeGyJQerTTZAN1OoNvi2c='; script-src-attr 'none'; style-src 'self'; style-src-attr 'none'; img-src 'self' https://mc.yandex.ru; connect-src 'self' https://mc.yandex.ru wss://mc.yandex.ru; font-src 'self'; manifest-src 'self'; media-src 'none'; worker-src blob: https://mc.yandex.ru; child-src blob: https://mc.yandex.ru; frame-src blob: https://mc.yandex.ru; form-action 'self'; upgrade-insecure-requests"
        />
      )
    }
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="yandex-verification" content="2460cb2e96b2ca3f" />
    {robotsContent && <meta name="robots" content={robotsContent} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {
      languageAlternates.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    {
      openGraph && canonicalUrl && (
        <>
          <meta property="og:type" content="website" />
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:url" content={canonicalUrl} />
          <meta property="og:site_name" content="Alexander Yurchenko" />
          <meta property="og:locale" content={ogLocale} />
          <meta property="og:locale:alternate" content={ogAlternateLocale} />
          <meta property="og:image" content={openGraph.imageUrl} />
          <meta property="og:image:type" content="image/png" />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content={openGraph.imageAlt} />
        </>
      )
    }
    {
      structuredData && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
    <link rel="icon" href="/image/favicon/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/image/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/image/favicon/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/image/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/image/favicon/site.webmanifest" />
    <meta name="theme-color" content="#f7f5ef" />
    <title>{title}</title>
    {isProduction && <script defer src="/js/yandex-metrica.js"></script>}
    <ClientRouter />
  </head>
  <body>
    {
      isProduction && (
        <noscript>
          <div>
            <img
              class="yandex-metrica__noscript-image"
              src="https://mc.yandex.ru/watch/110345045"
              alt=""
            />
          </div>
        </noscript>
      )
    }
    <a class="skip-link" href="#main-content">{skipLinkText}</a>
    <div
      class:list={[
        'site-shell',
        hasSidebar && 'site-shell--with-sidebar',
        !hasSidebar && 'site-shell--single',
        hasLanguageSwitcher && 'site-shell--has-language',
      ]}
    >
      {
        hasLanguageSwitcher && (
          <nav class="language-switcher" aria-label={languageSwitcherLabel}>
            <Icon
              class="sidebar-icon language-switcher__icon"
              name="mdi:translate"
              aria-hidden="true"
            />
            <slot name="language-switcher" />
          </nav>
        )
      }
      {
        hasSidebar && (
          <aside class="identity-panel" data-identity-panel>
            {hasProfilePhoto && (
              <div class="identity-panel__photo" data-profile-photo>
                <slot name="profile-photo" />
              </div>
            )}
            {Astro.slots.has('sidebar-content') && (
              <div class="identity-panel__content">
                <slot name="sidebar-content" />
              </div>
            )}
          </aside>
        )
      }
      <main id="main-content" class="content-area" tabindex="-1">
        {
          hasProfileHeader && (
            <header class="profile-header" data-profile-header>
              {Astro.slots.has('profile-name') && (
                <h1 class="profile-header__name">
                  <slot name="profile-name" />
                </h1>
              )}
              {Astro.slots.has('profile-role') && (
                <p class="profile-header__role">
                  <slot name="profile-role" />
                </p>
              )}
            </header>
          )
        }
        <slot />
      </main>
    </div>
    <script defer src="/js/site.js"></script>
  </body>
</html>
