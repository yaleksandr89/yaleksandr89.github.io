---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
  lang="en"
  title="404 — Page not found"
  description="The requested page could not be found."
  robotsContent="noindex, follow"
>
  <div class="not-found-page">
    <nav class="language-switcher not-found-page__language" aria-label="Language selection">
      <Icon
        class="sidebar-icon language-switcher__icon"
        name="mdi:translate"
        aria-hidden="true"
      />
      <div class="language-switcher__control">
        <a class="language-switcher__item" href="/404.html">RU</a>
        <span class="language-switcher__item" aria-current="page">EN</span>
      </div>
    </nav>

    <article class="not-found">
      <div class="not-found__rail" aria-hidden="true">
        <p class="not-found__code">404</p>
      </div>

      <div class="not-found__content">
        <h1 class="not-found__title">Page not found</h1>
        <p class="not-found__copy">
          The link may be outdated or the address may have been entered incorrectly.
        </p>
        <p class="not-found__copy">Choose a site version to continue.</p>

        <div class="not-found__actions">
          <a class="text-link not-found__action" href="/">
            <span class="text-link__label">Go to Russian homepage</span>
          </a>
          <a class="text-link not-found__action" href="/en/">
            <span class="text-link__label">Go to English homepage</span>
          </a>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
