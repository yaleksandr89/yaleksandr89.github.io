---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="en"
  title="Portfolio"
  description="Personal website."
>
  <img
    slot="profile-photo"
    src="/image/yaleksandr89.jpg"
    alt="Portrait of Alexander Yurchenko"
  />
  <span slot="profile-name">Alexander Yurchenko</span>
  <span slot="profile-role">PHP Backend Developer</span>
  <div slot="language-switcher">
    <a href="/">RU</a> / <span>EN</span>
  </div>

  <div slot="sidebar-content">
    <section class="sidebar-section">
      <h2>Contacts</h2>
      <div class="sidebar-section__body">
        <address>
          <ul class="contact-list">
            <li><span>Location:</span> <span>Saint Petersburg, Russia</span></li>
            <li><span>Telegram:</span> <a href="https://t.me/yaleksandr89" target="_blank" rel="noopener noreferrer nofollow">https://t.me/yaleksandr89</a></li>
            <li><span>Email:</span> <a href="mailto:y.aleksandr89@gmail.com">y.aleksandr89@gmail.com</a></li>
            <li><span>LinkedIn:</span> <a href="https://linkedin.com/in/yaleksandr89" target="_blank" rel="noopener noreferrer nofollow">https://linkedin.com/in/yaleksandr89</a></li>
            <li><span>GitHub:</span> <a href="https://github.com/yaleksandr89" target="_blank" rel="noopener noreferrer nofollow">https://github.com/yaleksandr89</a></li>
          </ul>
        </address>
        <div class="cv-download">
          <h3 class="cv-download__title">CV (PDF)</h3>
          <label class="cv-download__option" for="cv-phone-en">
            <input id="cv-phone-en" type="checkbox" data-cv-toggle />
            <span>Include phone number in contacts</span>
          </label>
          <a
            class="cv-download__link"
            href="/cv/cv_yurchenko_a_a_en_2026_without_phone.pdf"
            download="cv_yurchenko_a_a_en_2026_without_phone.pdf"
            data-cv-link
            data-cv-with-phone-href="/cv/cv_yurchenko_a_a_en_2026.pdf"
            data-cv-with-phone-download="cv_yurchenko_a_a_en_2026.pdf"
            data-cv-with-phone-text="Download CV with phone number (PDF)"
            data-cv-without-phone-href="/cv/cv_yurchenko_a_a_en_2026_without_phone.pdf"
            data-cv-without-phone-download="cv_yurchenko_a_a_en_2026_without_phone.pdf"
            data-cv-without-phone-text="Download CV without phone (PDF)"
          >
            <svg class="cv-download__icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24">
              <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 19h14" />
            </svg>
            <span data-cv-link-text>Download CV without phone (PDF)</span>
          </a>
        </div>
      </div>
    </section>

    <section class="sidebar-section">
      <h2>Education</h2>
      <div class="sidebar-section__body">
        <article class="sidebar-entry">
          <h3>Northern Arctic Federal University named after M. V. Lomonosov</h3>
          <a href="https://narfu.ru" target="_blank" rel="noopener noreferrer nofollow">https://narfu.ru</a>
          <p class="sidebar-entry__period">2011 - 2016</p>
          <p class="sidebar-entry__line">Bachelor’s degree</p>
          <p class="sidebar-entry__line">Information Systems and Technologies</p>
        </article>
      </div>
    </section>

    <section class="sidebar-section">
      <h2>Courses</h2>
      <div class="sidebar-section__body">
        <ul class="sidebar-entry-list">
          <li>
            <article class="sidebar-entry">
              <p class="sidebar-entry__period">June 2025 - April 2026</p>
              <h3>Hexlet</h3>
              <a href="https://ru.hexlet.io" target="_blank" rel="noopener noreferrer nofollow">https://ru.hexlet.io</a>
              <p class="sidebar-entry__line">PHP Developer Profession</p>
            </article>
          </li>
          <li>
            <article class="sidebar-entry">
              <p class="sidebar-entry__period">May 2025 - June 2025</p>
              <h3>Stepik</h3>
              <a href="https://stepik.org" target="_blank" rel="noopener noreferrer nofollow">https://stepik.org</a>
              <p class="sidebar-entry__line">Interactive SQL Trainer</p>
            </article>
          </li>
          <li>
            <article class="sidebar-entry">
              <p class="sidebar-entry__period">June 2025</p>
              <h3>Stepik</h3>
              <a href="https://stepik.org" target="_blank" rel="noopener noreferrer nofollow">https://stepik.org</a>
              <p class="sidebar-entry__line">Postman for Testing</p>
            </article>
          </li>
          <li>
            <article class="sidebar-entry">
              <p class="sidebar-entry__period">February 2022</p>
              <h3>Udemy</h3>
              <a href="https://udemy.com" target="_blank" rel="noopener noreferrer nofollow">https://udemy.com</a>
