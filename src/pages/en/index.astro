        'Laravel',
        'Symfony',
        'PostgreSQL',
        'MariaDB',
        'REST API',
        'Third-party integrations',
        'Redis',
        'Elasticsearch',
        'Sphinx',
        'Docker',
        'Linux/Ubuntu',
        'Legacy code',
        'Refactoring',
        'Migrations',
        'Business logic',
        'Bug fixing',
      ],
    },
