    imageUrl: 'https://yaleksandr89.github.io/image/social/og-en.png',
    imageAlt: 'Alexander Yurchenko — PHP Backend / Laravel Developer',
  }}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    inLanguage: 'en',
    url: 'https://yaleksandr89.github.io/en/',
    name: 'Alexander Yurchenko — PHP Backend / Laravel Developer',
