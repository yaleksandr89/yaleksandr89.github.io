  description="PHP Backend / Laravel Developer with 5+ years of commercial experience in Laravel, Symfony, REST API, third-party integrations, and legacy projects."
  canonicalUrl="https://yaleksandr89.github.io/en/"
  languageAlternates={[
    { hreflang: 'ru', href: 'https://yaleksandr89.github.io/' },
    { hreflang: 'en', href: 'https://yaleksandr89.github.io/en/' },
    { hreflang: 'x-default', href: 'https://yaleksandr89.github.io/' },
