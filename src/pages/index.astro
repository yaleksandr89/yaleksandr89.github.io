            <li>Laravel</li>
            <li>MariaDB</li>
            <li>Redis</li>
            <li>Docker</li>
            <li>Elasticsearch</li>
            <li>GitLab</li>
            <li>Ubuntu</li>
            <li>PhpStorm</li>
          </ul>
        </div>
        <details class="experience-entry__responsibilities" open data-disclosure data-mobile-collapse>
          <summary class="experience-entry__label">
            <span class="disclosure-toggle__compact" aria-hidden="true">
              <Icon class="disclosure-toggle__icon" name="mdi:chevron-down" aria-hidden="true" />
            </span>
            <span>Задачи и результаты:</span>
          </summary>
