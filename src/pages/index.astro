              <span class="contact-list__value">
                <a class="text-link" href="https://spb.hh.ru/resume/b2eaac8aff097cfcdc0039ed1f45507a725a36" target="_blank" rel="noopener noreferrer nofollow"><span class="text-link__label">Резюме на hh.ru</span></a>
              </span>
            </li>
            <li class="contact-list__item">
              <Icon class="sidebar-icon contact-list__icon" name="fa6-brands:vk" aria-hidden="true" />
