---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
  lang="ru"
  title="Александр Юрченко — PHP Backend / Laravel Developer"
  description="PHP Backend / Laravel Developer с 5+ годами коммерческого опыта: Laravel, Symfony, REST API, внешние интеграции и развитие legacy-проектов."
  canonicalUrl="https://yaleksandr89.github.io/"
  languageAlternates={[
    { hreflang: 'ru', href: 'https://yaleksandr89.github.io/' },
    { hreflang: 'en', href: 'https://yaleksandr89.github.io/en/' },
    { hreflang: 'x-default', href: 'https://yaleksandr89.github.io/' },
  ]}
>
  <img
    slot="profile-photo"
    src="/image/yaleksandr89.jpg"
    alt="Портрет Александра Юрченко"
  />
  <span slot="profile-name">Александр Юрченко</span>
  <span slot="profile-role">PHP Backend-разработчик</span>
  <div class="language-switcher__control" slot="language-switcher">
    <span class="language-switcher__item" aria-current="page">RU</span>
    <a class="language-switcher__item" href="/en/">EN</a>
