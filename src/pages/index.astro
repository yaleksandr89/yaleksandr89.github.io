        <input class="cv-download__checkbox" id="cv-phone-ru" type="checkbox" data-cv-toggle />
        <span class="cv-download__checkbox-control" aria-hidden="true">
          <Icon class="cv-download__checkbox-icon" name="mdi:check" aria-hidden="true" />
        </span>
        <span>Добавить телефон в контакты</span>
      </label>
      <a
        class="cv-download__link"
        href="/cv/cv_yurchenko_a_a_rus_2026_without_phone.pdf"
        download="cv_yurchenko_a_a_rus_2026_without_phone.pdf"
        data-cv-link
        data-cv-with-phone-href="/cv/cv_yurchenko_a_a_rus_2026.pdf"
        data-cv-with-phone-download="cv_yurchenko_a_a_rus_2026.pdf"
        data-cv-with-phone-text="Скачать резюме с телефоном (PDF)"
        data-cv-without-phone-href="/cv/cv_yurchenko_a_a_rus_2026_without_phone.pdf"
        data-cv-without-phone-download="cv_yurchenko_a_a_rus_2026_without_phone.pdf"
        data-cv-without-phone-text="Скачать резюме без телефона (PDF)"
      >
        <Icon class="sidebar-icon cv-download__icon" name="mdi:download" aria-hidden="true" />
        <span data-cv-link-text>Скачать резюме без телефона (PDF)</span>
      </a>
      <hr class="sidebar-divider" />
    </section>

    <details class="sidebar-section sidebar-disclosure" open data-disclosure>
      <summary class="sidebar-section__summary">
        <span class="disclosure-toggle__accent" aria-hidden="true">
          <Icon class="disclosure-toggle__icon" name="mdi:chevron-down" aria-hidden="true" />
        </span>
        <span class="disclosure-toggle__title">Контакты</span>
      </summary>
      <div class="sidebar-section__body">
        <address>
          <ul class="contact-list">
